{
  "name": "@atlas/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx wrangler dev --local --port 3001",
    "build": "tsc --noEmit",
    "deploy": "npx wrangler deploy",
    "export:sqlite": "node ./scripts/export-sqlite-to-d1.mjs",
    "resync:sqlite": "node --import tsx ./scripts/resync-local-sqlite.ts",
    "smoke:worker": "node --import tsx ./scripts/smoke-worker.ts",
    "start": "npm run deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.3.3",
    "@fastify/cors": "^11.0.1",
    "better-sqlite3": "^11.9.1",
    "node-ical": "^0.20.1",
    "zod": "^3.24.4",
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "tsx": "^4.19.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3"
  }
}
